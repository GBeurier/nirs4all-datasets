{
  "$defs": {
    "AlignmentLevel": {
      "description": "How a source's spectra align to samples / to other sources.",
      "enum": [
        "observation",
        "sample"
      ],
      "title": "AlignmentLevel",
      "type": "string"
    },
    "Author": {
      "additionalProperties": false,
      "description": "A dataset author for DataCite/Dataverse metadata.",
      "properties": {
        "affiliation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Affiliation"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "orcid": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Orcid"
        },
        "ror": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ror"
        }
      },
      "required": [
        "name"
      ],
      "title": "Author",
      "type": "object"
    },
    "AxisUnit": {
      "description": "Spectral axis unit (mirrors ``nirs4all`` ``HeaderUnit``).",
      "enum": [
        "cm-1",
        "nm",
        "none",
        "text",
        "index"
      ],
      "title": "AxisUnit",
      "type": "string"
    },
    "Canonicalization": {
      "additionalProperties": false,
      "description": "How retrieved raw resources become v2-standard or canonical dataset files.",
      "properties": {
        "delegate": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delegate"
        },
        "delegate_sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delegate Sha256"
        },
        "engine": {
          "$ref": "#/$defs/CanonicalizationEngine",
          "default": "manual"
        },
        "expected_files": {
          "items": {
            "type": "string"
          },
          "title": "Expected Files",
          "type": "array"
        },
        "expected_layout": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expected Layout"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "parameters": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "integer"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "title": "Parameters",
          "type": "object"
        },
        "recipe_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Recipe Id"
        },
        "recipe_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Recipe Version"
        }
      },
      "title": "Canonicalization",
      "type": "object"
    },
    "CanonicalizationEngine": {
      "description": "Engine that can turn retrieved resources into the local dataset layout.",
      "enum": [
        "rust_recipe",
        "nirs4all_io",
        "nirs4all_formats",
        "python_compat",
        "rscript_compat",
        "delegate",
        "manual"
      ],
      "title": "CanonicalizationEngine",
      "type": "string"
    },
    "ConversionStatus": {
      "description": "Outcome of raw->canonical conversion.",
      "enum": [
        "ok",
        "partial",
        "failed"
      ],
      "title": "ConversionStatus",
      "type": "string"
    },
    "DataCite": {
      "additionalProperties": false,
      "description": "Rich metadata mapped onto native Dataverse/DataCite fields at publish.",
      "properties": {
        "authors": {
          "items": {
            "$ref": "#/$defs/Author"
          },
          "title": "Authors",
          "type": "array"
        },
        "funding": {
          "items": {
            "$ref": "#/$defs/Funding"
          },
          "title": "Funding",
          "type": "array"
        },
        "related_publications": {
          "items": {
            "$ref": "#/$defs/PublicationRef"
          },
          "title": "Related Publications",
          "type": "array"
        },
        "related_software": {
          "items": {
            "type": "string"
          },
          "title": "Related Software",
          "type": "array"
        }
      },
      "title": "DataCite",
      "type": "object"
    },
    "DataverseRef": {
      "additionalProperties": false,
      "description": "Pointer to the dataset's (future) personal Dataverse location and pinned version \u2014 the\ntoken-gated fallback for private/anonymized data and for origins that have rotted.",
      "properties": {
        "dataset_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dataset Version"
        },
        "doi": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Doi"
        },
        "instance": {
          "default": "https://entrepot.recherche.data.gouv.fr",
          "title": "Instance",
          "type": "string"
        }
      },
      "title": "DataverseRef",
      "type": "object"
    },
    "Funding": {
      "additionalProperties": false,
      "description": "Funding information for DataCite metadata.",
      "properties": {
        "award_number": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Award Number"
        },
        "award_title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Award Title"
        },
        "funder": {
          "title": "Funder",
          "type": "string"
        }
      },
      "required": [
        "funder"
      ],
      "title": "Funding",
      "type": "object"
    },
    "Generation": {
      "additionalProperties": false,
      "description": "Provenance for a machine-generated descriptor (bulk bootstrap). Present only on auto-generated\ndescriptors; excluded from the processing hash so refreshing it never triggers a rebuild.",
      "properties": {
        "generator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Generator"
        },
        "generator_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Generator Version"
        },
        "managed": {
          "default": false,
          "title": "Managed",
          "type": "boolean"
        },
        "source_fingerprint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Fingerprint"
        },
        "source_relpath": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Relpath"
        }
      },
      "title": "Generation",
      "type": "object"
    },
    "Governance": {
      "additionalProperties": false,
      "description": "Legal/ethical metadata. Public release is gated on these fields (see publication_blockers).",
      "properties": {
        "access_policy": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Access Policy"
        },
        "anonymization_status": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Anonymization Status"
        },
        "consent_ethics_status": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Consent Ethics Status"
        },
        "license": {
          "title": "License",
          "type": "string"
        },
        "owner_steward": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Owner Steward"
        },
        "permitted_use": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Permitted Use"
        },
        "redistribution_rights": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Redistribution Rights"
        }
      },
      "required": [
        "license"
      ],
      "title": "Governance",
      "type": "object"
    },
    "IdentitySpec": {
      "additionalProperties": false,
      "description": "The id columns that link spectra <-> samples <-> Y/metadata. ``observation_id`` is per-spectrum;\n``sample_id`` is the physical sample (groups repetitions). When ``sample_id`` is unavailable, each\nobservation is its own sample group.",
      "properties": {
        "observation_id": {
          "default": "observation_id",
          "title": "Observation Id",
          "type": "string"
        },
        "sample_id": {
          "default": "sample_id",
          "title": "Sample Id",
          "type": "string"
        },
        "sample_id_available": {
          "default": true,
          "title": "Sample Id Available",
          "type": "boolean"
        }
      },
      "title": "IdentitySpec",
      "type": "object"
    },
    "Modality": {
      "description": "Spectroscopic modality.",
      "enum": [
        "NIR",
        "MIR",
        "Raman",
        "UV-Vis",
        "VSWIR",
        "TIR",
        "hyperspectral",
        "other"
      ],
      "title": "Modality",
      "type": "string"
    },
    "OriginSource": {
      "additionalProperties": false,
      "description": "An original (authoritative) home of a dataset's bytes \u2014 where to fetch from, never checksums\n(the manifest is the single byte-identity authority). Excluded from the processing hash.",
      "properties": {
        "access": {
          "$ref": "#/$defs/SourceAccess",
          "default": "open"
        },
        "alive": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Alive"
        },
        "credential_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Credential Ref"
        },
        "expected_files": {
          "items": {
            "type": "string"
          },
          "title": "Expected Files",
          "type": "array"
        },
        "kind": {
          "$ref": "#/$defs/SourceKind"
        },
        "last_checked": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Checked"
        },
        "license": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "License"
        },
        "locator": {
          "title": "Locator",
          "type": "string"
        },
        "mode": {
          "$ref": "#/$defs/SourceMode",
          "default": "raw"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        }
      },
      "required": [
        "kind",
        "locator"
      ],
      "title": "OriginSource",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "description": "Where the data came from and how it was converted.",
      "properties": {
        "collection_date": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Collection Date"
        },
        "contributor": {
          "title": "Contributor",
          "type": "string"
        },
        "conversion_status": {
          "anyOf": [
            {
              "$ref": "#/$defs/ConversionStatus"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "ingest_reader": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ingest Reader"
        },
        "ingest_reader_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ingest Reader Version"
        },
        "known_exclusions": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Known Exclusions"
        },
        "lab_protocol": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lab Protocol"
        },
        "raw_sha256": {
          "items": {
            "type": "string"
          },
          "title": "Raw Sha256",
          "type": "array"
        },
        "reference_method": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference Method"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "contributor"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "PublicationRef": {
      "additionalProperties": false,
      "description": "A related publication (the *paper*), for citation. ``doi`` is a journal/publisher DOI \u2014 distinct\nfrom a data-repository DOI, which is an :class:`OriginSource` (where the *bytes* live).",
      "properties": {
        "authors": {
          "items": {
            "type": "string"
          },
          "title": "Authors",
          "type": "array"
        },
        "bibtex": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Bibtex"
        },
        "citation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Citation"
        },
        "doi": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Doi"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        },
        "year": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Year"
        }
      },
      "title": "PublicationRef",
      "type": "object"
    },
    "Retrieval": {
      "additionalProperties": false,
      "description": "User-side retrieval plan, distinct from publication/redistribution rights.",
      "properties": {
        "blockers": {
          "items": {
            "type": "string"
          },
          "title": "Blockers",
          "type": "array"
        },
        "canonical_hosted": {
          "default": false,
          "title": "Canonical Hosted",
          "type": "boolean"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "public_redistributable": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Public Redistributable"
        },
        "public_retrievable": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Public Retrievable"
        },
        "routes": {
          "items": {
            "$ref": "#/$defs/RetrievalRoute"
          },
          "title": "Routes",
          "type": "array"
        },
        "schema_version": {
          "default": "1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/RetrievalStatus",
          "default": "documented_only"
        }
      },
      "title": "Retrieval",
      "type": "object"
    },
    "RetrievalFormat": {
      "description": "File format expected after locating/downloading a resource.",
      "enum": [
        "csv",
        "csv_gz",
        "xlsx",
        "zip",
        "mat",
        "rda",
        "rds",
        "openspecy_rds",
        "jcamp_dx",
        "sqlite",
        "spc",
        "parquet",
        "json",
        "txt",
        "ecostress_spectrum_txt",
        "unknown"
      ],
      "title": "RetrievalFormat",
      "type": "string"
    },
    "RetrievalHealth": {
      "additionalProperties": false,
      "description": "How a route should be probed during maintenance checks.",
      "properties": {
        "expected_status": {
          "items": {
            "type": "integer"
          },
          "title": "Expected Status",
          "type": "array"
        },
        "probe": {
          "default": true,
          "title": "Probe",
          "type": "boolean"
        }
      },
      "title": "RetrievalHealth",
      "type": "object"
    },
    "RetrievalMethod": {
      "description": "How a retrieval route is executed.",
      "enum": [
        "canonical_fetch",
        "raw_retrieve",
        "delegate",
        "manual"
      ],
      "title": "RetrievalMethod",
      "type": "string"
    },
    "RetrievalProvider": {
      "description": "Provider/resolver used to locate remote resources.",
      "enum": [
        "url",
        "dataverse",
        "zenodo",
        "figshare",
        "ckan",
        "google_storage",
        "github",
        "timeseriesclassification",
        "jpl_ecostress",
        "local_path",
        "manual",
        "script",
        "unknown"
      ],
      "title": "RetrievalProvider",
      "type": "string"
    },
    "RetrievalResource": {
      "additionalProperties": false,
      "description": "One raw/canonical resource that can be downloaded or located locally.",
      "properties": {
        "compression": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Compression"
        },
        "file_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "File Name"
        },
        "format": {
          "$ref": "#/$defs/RetrievalFormat",
          "default": "unknown"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "role": {
          "$ref": "#/$defs/RetrievalResourceRole",
          "default": "raw"
        },
        "selector": {
          "$ref": "#/$defs/RetrievalSelector"
        },
        "sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sha256"
        },
        "size": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Size"
        },
        "unpack": {
          "$ref": "#/$defs/RetrievalUnpack"
        }
      },
      "required": [
        "id",
        "selector"
      ],
      "title": "RetrievalResource",
      "type": "object"
    },
    "RetrievalResourceRole": {
      "description": "Role of a retrieved raw/canonical resource.",
      "enum": [
        "spectra",
        "targets",
        "metadata",
        "archive",
        "split",
        "license",
        "readme",
        "raw",
        "canonical",
        "other"
      ],
      "title": "RetrievalResourceRole",
      "type": "string"
    },
    "RetrievalRoute": {
      "additionalProperties": false,
      "description": "One retrieval route, tried by priority by future resolvers.",
      "properties": {
        "access": {
          "$ref": "#/$defs/SourceAccess",
          "default": "open"
        },
        "api_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Api Url"
        },
        "automated_download_allowed": {
          "default": true,
          "title": "Automated Download Allowed",
          "type": "boolean"
        },
        "canonicalization": {
          "anyOf": [
            {
              "$ref": "#/$defs/Canonicalization"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "citation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Citation"
        },
        "health": {
          "$ref": "#/$defs/RetrievalHealth"
        },
        "id": {
          "title": "Id",
