[workspace.dependencies]
nirs4all-datasets-core = { path = "vendored/nirs4all-datasets-core", version = "${WS_VERSION}" }
nirs4all-formats-core = { path = "vendored/nirs4all-formats-core", version = "${FORMATS_VERSION}" }
nirs4all-formats = { path = "vendored/nirs4all-formats", version = "${FORMATS_VERSION}" }
nirs4all-io-core = { path = "vendored/nirs4all-io-core", version = "${IO_VERSION}" }
nirs4all-io = { path = "vendored/nirs4all-io", version = "${IO_VERSION}" }
serde = { version = "1.0", features = ["derive"] }
