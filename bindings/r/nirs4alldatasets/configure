    "vendored/nirs4all-datasets-core",
    "vendored/nirs4all-datasets-capi",
    "vendored/nirs4all-formats-core",
    "vendored/nirs4all-formats",
    "vendored/nirs4all-io-core",
    "vendored/nirs4all-io",
]

[workspace.package]
version = "${WS_VERSION}"
edition = "2021"
