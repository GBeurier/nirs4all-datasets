# Self-contained OFFLINE build of the nirs4all-datasets Rust core into a STATICLIB,
# then compile the C shim (n4ds.c) and link the staticlib by exact path. No
# prebuilt nirs4all-datasets-capi cdylib, no N4DS_CAPI_DIR — the package vendors and
# compiles its own staticlib (see ../configure, N4DS_R_VENDOR=1). The committed
# C ABI header lives next to the shim (src/nirs4all_datasets.h), copied by
# ./configure.
#
# This mirrors the CRAN "Using Rust" / rextendr Makevars pattern: every cargo
# invocation runs with a BUILD-LOCAL CARGO_HOME and CARGO_TARGET_DIR (never the
# user's ~/.cargo / ~/.rustup, per CRAN Policy), and a post-link `rust_clean`
# rule wipes all Rust build scratch out of the package source so R CMD check
# --as-cran never scans third-party build artefacts.
#
# CRAN requires configure/build discovery for both separately packaged Rust tools,
# first on PATH and then in ~/.cargo/bin. Keep that search inside the recipe: a
# Make-level exported immediate assignment uses two GNU extensions and triggers the
# non-portable Makevars check. Cargo.lock is format 4 and the bundled manifests use
# Edition 2024, hence Cargo >= 1.85. The current resolved vendor closure requires
# rustc >= 1.88.0 (zip 8.6.0 directly, and time 0.3.53).
CARGO_MIN_VERSION = 1.85.0
RUSTC_MIN_VERSION = 1.88.0
-include n4ds-rust-toolchain.mk

TMP_ROOT = $(if $(TMPDIR),$(TMPDIR),$(if $(TEMP),$(TEMP),$(if $(TMP),$(TMP),/tmp)))
TARGET_DIR = $(TMP_ROOT)/n4ds-r-target
LIBDIR = $(TARGET_DIR)/release
STATLIB = $(LIBDIR)/libnirs4all_datasets_capi.a
# Reference the staticlib by EXACT PATH, not `-L$(LIBDIR) -lnirs4all_datasets_capi`:
# the configure-generated vendored capi crate emits the STATICLIB only (its
# [lib] crate-type is reduced to ["staticlib"]), but referencing it by exact .a
# path also guards against any stray .so and forces the static link, baking every
# n4ds_* symbol into nirs4alldatasets.so (self-contained, no runtime rpath needed).
PKG_LIBS = $(STATLIB)
PKG_CPPFLAGS = -I$(CURDIR)

# Build-local cargo state. CRAN Policy forbids writing to the user's HOME at
# install time; the cargo registry/cache (~/.cargo) and target dir must both
# live INSIDE the package build tree and be removed afterwards. CARGO_HOME holds
# the registry index + git db; pointing it here keeps cargo off ~/.cargo. The
# rust/vendor tree is extracted from vendor.tar.xz so the build is fully OFFLINE
# and never reaches the network either.
CARGOTMP = $(TMP_ROOT)/n4ds-r-cargo
VENDOR_ROOT = $(TMP_ROOT)/n4ds-r-vendor
VENDOR_DIR = $(VENDOR_ROOT)/vendor

# `all` links the SHLIB, THEN runs rust_clean (which depends on $(SHLIB), so it
# is sequenced last). rust_clean removes the whole target/ + CARGOTMP + the
# extracted vendor/ so nothing Rust-related is left in the installed source for
# R CMD check to scan.
all: $(SHLIB) rust_clean

.PHONY: all rust_clean clean C_clean $(STATLIB)

$(SHLIB): $(STATLIB)

# Report both selected versions before Cargo can print its first "Compiling" line;
# R CMD check --as-cran uses that ordering for its Rust compilation check. The
# selected rustc is passed explicitly to Cargo, so a personal fallback works even
# when ~/.cargo/bin was absent from the installer's PATH. CARGO_HOME and target/
# remain build-local, the vendor archive remains offline, and `-j 2` bounds Cargo.
$(STATLIB):
	@rust_tool_version () { \
		rust_tool_output=`"$$1" --version 2>/dev/null` || return 1; \
		set -- $$rust_tool_output; \
		[ "$$#" -ge 2 ] || return 1; \
		rust_tool_version=$$2; \
		rust_tool_version=$${rust_tool_version%%-*}; \
		case "$$rust_tool_version" in ""|*[!0-9.]*) return 1 ;; esac; \
		printf '%s\n' "$$rust_tool_version"; \
	}; \
	rust_version_at_least () { \
		awk -v have="$$1" -v need="$$2" 'BEGIN { \
			have_count = split(have, have_parts, "."); \
			need_count = split(need, need_parts, "."); \
			count = have_count > need_count ? have_count : need_count; \
			for (i = 1; i <= count; i++) { \
				have_part = (i <= have_count ? have_parts[i] : 0) + 0; \
				need_part = (i <= need_count ? need_parts[i] : 0) + 0; \
				if (have_part > need_part) exit 0; \
				if (have_part < need_part) exit 1; \
			} \
			exit 0; \
		}'; \
	}; \
	find_suitable_rust_tool () { \
		rust_tool_name=$$1; \
		rust_tool_minimum=$$2; \
		rust_configured_candidate=; \
		case "$$rust_tool_name" in \
			cargo) rust_configured_candidate="$(N4DS_CARGO)" ;; \
			rustc) rust_configured_candidate="$(N4DS_RUSTC)" ;; \
		esac; \
		rust_path_candidate=`command -v "$$rust_tool_name" 2>/dev/null` || rust_path_candidate=; \
		rust_home_candidate=; \
		rust_home_exe_candidate=; \
		if [ -n "$${HOME:-}" ]; then \
			rust_home_candidate="$$HOME/.cargo/bin/$$rust_tool_name"; \
			rust_home_exe_candidate="$$rust_home_candidate.exe"; \
		fi; \
		rust_previous_candidate=; \
		for rust_candidate in "$$rust_configured_candidate" "$$rust_path_candidate" "$$rust_home_candidate" "$$rust_home_exe_candidate"; do \
			[ -n "$$rust_candidate" ] || continue; \
			[ "$$rust_candidate" != "$$rust_previous_candidate" ] || continue; \
			rust_previous_candidate=$$rust_candidate; \
			if [ "$$rust_candidate" != "$$rust_path_candidate" ] && [ ! -x "$$rust_candidate" ]; then continue; fi; \
			rust_candidate_version=`rust_tool_version "$$rust_candidate"` || { \
				if [ "$(N4DS_R_WASM)" = "1" ]; then \
					case "$$rust_candidate" in \
						*/rwasm/bin/cargo|*/rwasm/bin/rustc) \
							echo "nirs4alldatasets: accepting R-universe/rwasm $$rust_tool_name wrapper at $$rust_candidate; native version check is not available in the wasm tool wrapper" >&2; \
							printf '%s\n' "$$rust_candidate"; \
							return 0; \
							;; \
					esac; \
				fi; \
				echo "nirs4alldatasets: found $$rust_tool_name at $$rust_candidate but could not read its version" >&2; \
				continue; \
			}; \
			if rust_version_at_least "$$rust_candidate_version" "$$rust_tool_minimum"; then \
				printf '%s\n' "$$rust_candidate"; \
				return 0; \
			fi; \
			echo "nirs4alldatasets: found $$rust_tool_name $$rust_candidate_version at $$rust_candidate, but >= $$rust_tool_minimum is required" >&2; \
		done; \
		return 1; \
	}; \
	cargo=`find_suitable_rust_tool cargo "$(CARGO_MIN_VERSION)"` || { \
		echo "nirs4alldatasets: ERROR - Cargo >= $(CARGO_MIN_VERSION) was not found on PATH or in ~/.cargo/bin" >&2; \
		echo "Install or update Cargo and rustc using system packages or rustup: https://rustup.rs" >&2; \
		exit 1; \
	}; \
	rustc=`find_suitable_rust_tool rustc "$(RUSTC_MIN_VERSION)"` || { \
		echo "nirs4alldatasets: ERROR - rustc >= $(RUSTC_MIN_VERSION) was not found on PATH or in ~/.cargo/bin" >&2; \
		echo "Rust $(RUSTC_MIN_VERSION) is required by the bundled dependency closure (including zip 8.6.0)." >&2; \
		echo "Install or update Cargo and rustc using system packages or rustup: https://rustup.rs" >&2; \
		exit 1; \
	}; \
	"$$rustc" --version >&2 || { [ "$(N4DS_R_WASM)" = "1" ] && echo "rustc rwasm-wrapper ($$rustc)" >&2; }; \
	"$$cargo" --version >&2 || { [ "$(N4DS_R_WASM)" = "1" ] && echo "cargo rwasm-wrapper ($$cargo)" >&2; }; \
	if [ -z "$(TMP_ROOT)" ]; then \
		echo "nirs4alldatasets: ERROR - no usable temporary directory was found for build-local Cargo directories" >&2; \
		exit 1; \
	fi; \
	export RUSTC="$$rustc" && \
	export CARGO_HOME="$(CARGOTMP)" && \
	export CARGO_TARGET_DIR="$(TARGET_DIR)" && \
	case `uname -s 2>/dev/null || echo unknown` in \
		Darwin) export MACOSX_DEPLOYMENT_TARGET="$${MACOSX_DEPLOYMENT_TARGET:-14.0}" ;; \
	esac && \
	if [ -f rust/vendor.tar.xz ]; then \
		[ -d "$(VENDOR_DIR)" ] || ( \
			echo "extracting rust/vendor.tar.xz"; \
			rm -Rf "$(VENDOR_ROOT)" && mkdir -p "$(VENDOR_ROOT)" && \
			cd "$(VENDOR_ROOT)" && tar xJf "$(CURDIR)/rust/vendor.tar.xz" \
		); \
		cd rust && "$$cargo" build -p nirs4all-datasets-capi --release -j 2 --offline \
			--config 'source.crates-io.replace-with="vendored-sources"' \
			--config 'source.vendored-sources.directory="$(VENDOR_DIR)"'; \
	else \
		cd rust && "$$cargo" build -p nirs4all-datasets-capi --release -j 2; \
	fi

# Post-link cleanup. Runs AFTER $(SHLIB) has linked $(STATLIB) into the package
# .so, so the whole Rust scratch can go: the entire target/ (build-script scratch,
# .fingerprint/deps/incremental), the build-local CARGO_HOME, and the extracted
# vendor/ tree. This is what stops R CMD check --as-cran from scanning third-party
# build artefacts the package compiles but does not author. The committed inputs
# (rust/vendored/, rust/vendor.tar.xz, rust/Cargo.toml) are NOT touched. Skipped
# when NOT_CRAN=true (dev inner loop keeps the cache for incremental rebuilds).
rust_clean: $(SHLIB)
	@if [ "$(NOT_CRAN)" != "true" ]; then \
		rm -Rf "$(TARGET_DIR)" "$(CARGOTMP)" "$(VENDOR_ROOT)" "$(CURDIR)/rust/vendor" "$(CURDIR)/n4ds-rust-toolchain.mk"; \
	fi

C_clean:
	rm -Rf $(SHLIB) $(OBJECTS) $(STATLIB) $(TARGET_DIR) $(CARGOTMP) $(VENDOR_ROOT) $(CURDIR)/rust/vendor $(CURDIR)/n4ds-rust-toolchain.mk

clean: C_clean
