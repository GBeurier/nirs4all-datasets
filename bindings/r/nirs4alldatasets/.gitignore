# Self-contained Rust tree is populated by ./configure (N4DS_R_VENDOR=1) and the
# R-universe .prepare hook before R CMD build; it is NOT tracked (regenerated from
# the workspace crates/ + crates.io). Only src/n4ds.c + src/Makevars(.win) are the
# committed, layout-stable build inputs.
src/rust/vendored/
src/rust/vendor/
src/rust/vendor.tar.xz
src/rust/.cargo/
src/rust/Cargo.toml
src/rust/Cargo.lock
src/rust/target/
src/nirs4all_datasets.h

# Compiled artefacts from a local install.
src/*.o
src/*.so
src/*.dll
src/*.dylib
src/*.a

# Local install scratch.
.cargo/
nirs4alldatasets.Rcheck/
