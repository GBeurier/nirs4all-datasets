#!/bin/sh
# SPDX-License-Identifier: MIT
# R-universe pre-build hook.
#
# R-universe's build backend clones this repository and runs this script from the
# package directory BEFORE `R CMD build`, while the top-level
# nirs4all-datasets{-core,-capi} crates at ../../../crates are still on disk.
# If the sibling reader workspaces (nirs4all-formats and nirs4all-io) are not
# present next to this checkout, ./configure fetches the exact tagged versions
# declared in the root Cargo.toml before vendoring.
#
# `N4DS_R_VENDOR=1 ./configure` copies the core crates into src/rust/vendored/,
# emits a self-contained src/rust/Cargo.toml, copies the committed C ABI header,
# and `cargo vendor`s every crates.io transitive dep into src/rust/vendor.tar.xz
# with an offline source-replacement config. `R CMD build` then bundles those
# inputs into the source tarball, so every later step (the tarball's own configure
# on install) builds a self-contained, OFFLINE staticlib with no external crates/
# and no network.
set -e
N4DS_R_VENDOR=1 ./configure
