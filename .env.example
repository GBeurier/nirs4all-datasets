# Copy to .env (gitignored) for local development. The token is ONLY needed for
# uploading/publishing datasets and for downloading private/restricted ones.
# Public datasets are fetched (and cached) without any token.

# Recherche Data Gouv / Dataverse API token (account settings; 1-year lifetime).
NIRS4ALL_DATAVERSE_TOKEN=

# Dataverse instance base URL. Defaults to Recherche Data Gouv production.
# Sandbox: https://demo.recherche.data.gouv.fr
# CIRAD:   https://dataverse.cirad.fr
NIRS4ALL_DATAVERSE_INSTANCE=https://entrepot.recherche.data.gouv.fr
