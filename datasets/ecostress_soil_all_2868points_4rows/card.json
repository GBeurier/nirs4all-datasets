        "top_classes": [
          {
            "count": 1,
            "name": "The parent material is alluvium from mixed material, alluvial fine material overlayed on gypsum sandy loam, uncultivated from terracettes in lake plains. Light yellowish brown interior dry gravelly loam. Original ASTER Spectral Library name was jhu.becknic.soil.aridisol.calciorthid.coarse.79P1536.spectrum.txt"
          },
          {
            "count": 1,
            "name": "The parent material is alluvium from terracettes in lake plains, nonreclaimed salt-affected soil, barren land runoff. Dark brown interior moist clay loam, surface crust of 0.5 cm formed by salt deposition in microdepressions (fine-loamy, mixed, thermic typic salorthid). Original ASTER Spectral Library name was jhu.becknic.soil.aridisol.salorthid.coarse.79P1530.spectrum.txt"
          },
          {
            "count": 1,
            "name": "Parent material: alluvium over lacustrine material. Physiography: playa. Dark yellowish brown silty clay (Clayey over loamy, mixed thermic Typic Salorthid). Original ASTER Spectral Library name was jhu.becknic.soil.aridisol.salorthid.coarse.89P1805.spectrum.txt"
          },
          {
            "count": 1,
            "name": "Parent material: unconsolidated sediments from mixed-calcareous material, cropland. Physiography: backslope crested hills. Brown to dark brown clay (fine, montmorillonitic, thermic palexerollic chromoxerert). Original ASTER Spectral Library name was jhu.becknic.soil.vertisol.chromoxerert.coarse.88P475.spectrum.txt"
          }
        ]
