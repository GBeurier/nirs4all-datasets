      ],
      "name": "sample_description",
      "role": "metadata",
      "stats": {
        "n": 4,
        "n_classes": 4,
        "n_missing": 0,
        "top_classes": [
          {
            "count": 1,
            "name": "This is a medium to coarse-grained sample containing tremolite-actinolite crystals and talc. Amphibole is heavily altered to talc, and in addition to these phases there is quartz and some carbonate, as an alteration product, along with opaque grains. There may be heavily altered plagioclase present in this sample as well. Modes were 50.6% talc, 38% amphibole, 5.4% quartz, 3.6% calcite, 2.4% plagioclase remnants. Particle size was 0-75 Micrometer. Original ASTER Spectral Library name was jhu.becknic.rock.metamorphic.schist.fine.schist1.spectrum.txt"
          },
          {
            "count": 1,
            "name": "This is a very coarse-grained rock containing euhedral brown tourmaline poikiloblastically enclosing quartz remnants, large subhedra of muscovite enclosing remnants of tourmaline or much lesser quartz, and recrystallized quartz. Magnetite occurs scattered throughout this rock as well. Modes were 35% quartz, 33% tourmaline, 30.6% muscovite and 1.4% opaques. Particle size was 0-75 Micrometer. Original ASTER Spectral Library name was jhu.becknic.rock.metamorphic.schist.fine.schist4.spectrum.txt"
          },
          {
            "count": 1,
            "name": "Sample consists of a homogeneous microcrystalline carbonate matrix, with scattered flecks of reddish brown material and abundant fossils (primarily small bivalves) with recrystallized calcite. Some bivalves still show laminar structure. Very minor quartz was also noted in this section.Particle size was 0 - 75 Micrometers. Original ASTER Spectral Library name was jhu.becknic.rock.sedimentary.limestone.fine.limest1.spectrum.txt"
          },
          {
            "count": 1,
            "name": "The sample is a homogeneous microcrystalline carbonate with scattered flecks of a reddish brown (Fe-rich ?) material, which sometimes occurs as discontinuous bands throughout the section.Particle size was 0 - 75 Micrometers. Original ASTER Spectral Library name was jhu.becknic.rock.sedimentary.limestone.fine.limest5.spectrum.txt"
          }
        ]
      },
