# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Secrets — NEVER commit
.env
config.toml
*.token

# Ingestion staging (data bytes live on Dataverse, not Git)
incoming/

# Heavy dataset bytes live on Dataverse, not Git; cards/manifests/assets stay tracked.
datasets/*/raw/
datasets/*/canonical/

# Local download caches (pooch / requests)
.pooch/
*.cache

# Docs build + generated dataset pages
docs/_build/
docs/datasets/

# Generated interactive site + bulk run report (local; the site embeds its own asset copies)
/site/
bulk_report.json

# Heavy local authoritative source tree (the "NIRS DB" master + the archive it was extracted from).
# Like the dataset bytes, only the descriptors/cards derived from it live in git — never the source.
NIRS DB/
nirs_db/
OneDrive_*.zip
OneDrive_*.zip:Zone.Identifier

# Local code-intelligence index
.codegraph/

# Rust (the acquisition core + C ABI + bindings)
/target/
target/
**/*.rs.bk
bindings/python/target/
bindings/wasm/target/
bindings/wasm/pkg/
bindings/wasm/pkg-node/
bindings/wasm/pkg-web/
bindings/r/**/src/*.o
bindings/r/**/src/*.so
bindings/r/**/src/*.dll
bindings/r/**/src/rust/vendor/
bindings/r/**/src/rust/target/
bindings/matlab/*.mex*
bindings/matlab/*.oct
*.Rcheck/
# the embedded pyo3 extension is a build artefact (maturin builds it into src/)
src/nirs4all_datasets/_n4ds*.so
src/nirs4all_datasets/_n4ds*.pyd
src/nirs4all_datasets/_n4ds*.dylib
